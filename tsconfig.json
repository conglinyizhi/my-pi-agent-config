{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "target": "ES2024",
    "jsx": "react-jsx",
    "checkJs": false,
    "experimentalDecorators": false,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strict": true,
    "sourceMap": true,
    "types": ["node"],
    "noEmit": true
  },
  "exclude": ["node_modules", "**/node_modules/*"]
}
